FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install OpenSSH and Git
RUN apt-get update \
    && apt-get install -y openssh-server git \
    && rm -rf /var/lib/apt/lists/*

# Create a dedicated git user with /srv/git as home
RUN useradd -m -d /srv/git -s /usr/bin/bash git

# Seed gitconfig
COPY ./gitconfig /srv/git/.gitconfig

# Get useful server scripts
COPY ./scripts /scripts
RUN chmod -R +x /scripts

# Set up SSH for the git user
RUN mkdir -p /srv/git/.ssh \
    && chmod 700 /srv/git/.ssh \
    && chown -R git:git /srv/git

# Seed an authorized_keys file
COPY .temp/authorized_keys /srv/git/.ssh/authorized_keys
RUN chmod 600 /srv/git/.ssh/authorized_keys \
    && chown git:git /srv/git/.ssh/authorized_keys

# git-shell needs this directory to allow git-shell-commands (optional)
RUN mkdir -p /srv/git/git-shell-commands

# SSH privilege-separation directory
RUN mkdir -p /run/sshd

# Lock down sshd: key-based auth only, no root login, no passwords
RUN sed -i \
    -e 's/#PasswordAuthentication yes/PasswordAuthentication no/' \
    -e 's/#PubkeyAuthentication yes/PubkeyAuthentication yes/' \
    -e 's/#PermitRootLogin prohibit-password/PermitRootLogin no/' \
    /etc/ssh/sshd_config

# Repos will live under /scm
RUN mkdir -p /scm && chown git:git /scm

EXPOSE 22

CMD ["/usr/sbin/sshd", "-D"]